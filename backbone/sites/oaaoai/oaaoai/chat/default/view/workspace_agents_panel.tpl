<section class="oaao-agents-root flex flex-1 min-h-0 min-w-0 flex-col overflow-hidden bg-[var(--grid-paper)]" data-module="oaao-agents">
    <div class="oaao-agents-scroll flex flex-1 min-h-0 flex-col overflow-y-auto [overscroll-behavior-y:contain] [-webkit-overflow-scrolling:touch]">
        <div class="oaao-agents-shell oaao-gallery-page-column w-full box-border px-8 pt-8 pb-10 flex flex-col flex-1 min-h-0 min-w-0">
            <header class="oaao-agents-header shrink-0 pb-5">
                <h1 class="m-0 text-[1.375rem] fw-semibold fg-[var(--grid-ink)] tracking-tight" data-i18n="workspace.agents.page_title">Agents</h1>
                <p class="mt-2 mb-0 text-[0.875rem] leading-relaxed fg-[var(--grid-ink-muted)] max-w-[40rem]" data-i18n="workspace.agents.page_intro">
                    Capabilities available in this workspace. The task planner may enable a subset per run — configure in Settings → Task planner.
                </p>
            </header>
            <div class="oaao-agents-grid-host oaao-gallery-card-grid-container flex-1 min-h-0 min-w-0"
                data-oaao-agents="grid" aria-live="polite"></div>
        </div>
    </div>
</section>
