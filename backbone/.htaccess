    RewriteCond %{ENV:RAZY_DOMAIN} =localhost
    RewriteRule ^data/(.+)$ %{ENV:BASE}data/localhost-oaaoai/$1 [L]
    RewriteCond %{ENV:RAZY_DOMAIN} =localhost
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteCond $1 !^(index\.php|robots\.txt|sites|system|shared|plugins|library|asset|webassets|repository\.inc\.php|config\.inc\.php|sites\.inc\.php)
    RewriteRule ^(.*)$ %{ENV:BASE}index.php [L]
