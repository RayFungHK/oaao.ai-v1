RewriteEngine on

# OAAO_ORCHESTRATOR_SIDECAR — Apache ProxyPass handles /sidecar (not PHP).
RewriteRule ^sidecar(/.*)?$ - [L]

# Detect base directory for subdirectory installs
RewriteCond $0#%{REQUEST_URI} ^([^#]*)#(.*)\1$
RewriteRule ^.*$ - [E=BASE:%2]

# Pass through real files, symlinks, and directories. Virtual URLs (e.g. /webassets/…) are not files until rewritten below.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -l [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite the shared module location
RewriteRule ^\w+/shared/(.*)$ shared/$1 [L]

# ── Domain Detection ──
RewriteCond %{HTTP_HOST} ^localhost(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:localhost]
RewriteCond %{HTTP_HOST} ^.+\.localhost(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:*.localhost]
RewriteCond %{HTTP_HOST} ^.+\.invalid(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:*.invalid]
RewriteCond %{HTTP_HOST} ^admin\.localhost(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:admin.localhost]
RewriteCond %{HTTP_HOST} ^rayfung\.hk(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:rayfung.hk]
RewriteCond %{HTTP_HOST} ^.+\.rayfung\.hk(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:*.rayfung.hk]
RewriteCond %{HTTP_HOST} ^admin\.rayfung\.hk(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:admin.rayfung.hk]
RewriteCond %{HTTP_HOST} ^oaao\.rayfung\.hk(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:oaao.rayfung.hk]
RewriteCond %{HTTP_HOST} ^127\.0\.0\.1(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:localhost]
RewriteCond %{HTTP_HOST} ^host\.docker\.internal(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:localhost]
RewriteCond %{HTTP_HOST} ^web(:\d+)?$ [NC]
RewriteRule ^ - [E=RAZY_DOMAIN:localhost]

# ── Distributor Rewrite Rules ──
# [localhost] oaaoai (/)
    RewriteCond %{ENV:RAZY_DOMAIN} =localhost
    RewriteRule ^webassets/chat/(.+?)/(.+)$ sites/oaaoai/oaaoai/chat/$1/webassets/$2 [END]
