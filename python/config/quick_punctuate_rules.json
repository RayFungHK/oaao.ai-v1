{
  "punctuation_marks": "，。！？、；：,.!?",
  "comma_before_words": [
    "同埋",
    "而且",
    "但是",
    "所以",
    "因為",
    "如果",
    "或者",
    "不過",
    "然後",
    "另外"
  ],
  "question_patterns": [
    {
      "regex": "(意思)(?=乜)",
      "replacement": "\\1？"
    },
    {
      "regex": "(系乜嘢|係乜嘢)(嚟嘅)?(?=乜嘢|同埋|$)",
      "replacement": "\\1\\2？"
    },
    {
      "regex": "(叫做[^，。！？乜]+)(?=乜嘢|同埋|$)",
      "replacement": "\\1？"
    },
    {
      "regex": "(乜嘢)(?=叫做|同埋|$)",
      "replacement": "\\1？"
    },
    {
      "regex": "(点样|點樣)([^，。！？]*?)(?=呢|同埋|$)",
      "replacement": "\\1\\2？"
    },
    {
      "regex": "(呢[啲嘅]*[嘢个价])(?=，|$)",
      "replacement": "\\1？"
    },
    {
      "regex": "(乜嚟|系乜|係乜|咩嚟)(?=，同埋|$)",
      "replacement": "\\1？"
    },
    {
      "regex": "(系乜嘢|係乜嘢)(?=([^？?，。！]*?(系乜嘢|係乜嘢|同埋|权重|權重)))",
      "replacement": "\\1？，"
    },
    {
      "regex": "(权重|權重)(?=系乜嘢|係乜嘢)",
      "replacement": "，\\1"
    }
  ],
  "default_terminal": "。"
}
