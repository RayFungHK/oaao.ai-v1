{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaao.ai/schemas/v1/error.json",
  "title": "OAAOError",
  "description": "W4-S2 + W7-S1 — canonical error response envelope. Stable across PHP and Python tiers.",
  "type": "object",
  "required": ["ok", "error"],
  "properties": {
    "ok": { "const": false },
    "error": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^OAAO_E_[A-Z_]+$"
        },
        "detail": { "type": "string" },
        "cause": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
