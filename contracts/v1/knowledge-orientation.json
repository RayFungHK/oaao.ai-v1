{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaao.ai/schemas/v1/knowledge-orientation.json",
  "title": "KnowledgeOrientationV1",
  "description": "WS-1-S2 global orientation — platform or tenant scope (workspace is attribution only)",
  "type": "object",
  "required": ["version", "scope", "topics", "entities", "language"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "scope": { "type": "string", "enum": ["platform", "tenant"] },
    "tenant_id": { "type": ["integer", "null"], "minimum": 1 },
    "workspace_id": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Last contributing workspace (not the storage partition)"
    },
    "conversation_id": { "type": ["string", "null"], "maxLength": 128 },
    "topics": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "maxItems": 24
    },
    "entities": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "maxItems": 32
    },
    "language": { "type": "string", "maxLength": 32 },
    "recency_days": { "type": ["integer", "null"], "minimum": 1, "maximum": 365 },
    "search_queries_suggested": {
      "type": "array",
      "items": { "type": "string", "maxLength": 500 },
      "maxItems": 12
    },
    "do_not_search": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "maxItems": 24
    },
    "summary": { "type": "string", "maxLength": 2000 },
    "updated_at": { "type": "number" }
  },
  "additionalProperties": false
}
