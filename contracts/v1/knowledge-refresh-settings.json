{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaao.ai/schemas/v1/knowledge-refresh-settings.json",
  "title": "KnowledgeRefreshSettingsV1",
  "description": "WS-1-S6 — stored in oaao_purpose meta_json.knowledge_refresh (knowledge.platform.*)",
  "type": "object",
  "properties": {
    "scheduled_enabled": { "type": "boolean", "default": true },
    "interval_hours": { "type": "number", "minimum": 1, "maximum": 720, "default": 168 },
    "classify_after": { "type": "boolean", "default": true },
    "merge_recall": { "type": "boolean", "default": true },
    "do_not_search": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "maxItems": 24
    },
    "tenant_vault_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Tenant-global Knowledge vault (oaao_vault.id) for promoted web captures + RAG merge"
    },
    "platform_vault_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional platform-wide Knowledge vault"
    },
    "refresh_user_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Service account user_id for Vault document_upload_text ACL"
    }
  },
  "additionalProperties": false
}
