{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaao.ai/schemas/chat_run_request.json",
  "title": "ChatRunRequest",
  "type": "object",
  "required": ["endpoint", "messages"],
  "properties": {
    "conversation_id": { "type": ["string", "null"] },
    "purpose_id": { "type": "string", "default": "chat" },
    "mode_id": { "type": "string", "default": "default" },
    "planner_mode_id": {
      "type": "string",
      "enum": ["default", "tot", "ddtree"],
      "default": "default",
      "description": "Planner expansion mode — distinct from desk/default UI mode_id."
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["base_url", "model"],
      "properties": {
        "base_url": { "type": "string" },
        "model": { "type": "string" },
        "endpoint_ref": { "type": "string" }
      }
    },
    "allowed_agents": { "type": "array", "items": { "type": "string" } },
    "tool_servers": { "type": "array", "items": { "type": "object" } },
    "openai_tools": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
