# Copy to repo root as `.env` (docker compose loads it automatically).
# This repo also passes `docker/env` into containers via `env_file` in docker-compose.yml —
# keep production host vars here (OAAO_APEX_DOMAIN, OAAO_CUSTOMER_HOSTS, …).
#
# `docker-compose.yml` mounts `./backbone` into `web` by default — JS under sites/ updates live; recreate container after pulling compose changes (`docker compose up -d web`).
#
# Chat streaming: `web` starts once `orchestrator` container exists (`service_started`, not `service_healthy`) so vault job poll can reach PHP without a ~25s DNS gap. Sidecar SSE may need a few seconds to warm up on first chat.
#
# ── Vault document embed / RAG (required for local dev) ─────────────────────
# 1. Start core stack + vector DB (Qdrant is under Compose profile `vectors` — plain `docker compose up` does NOT start it):
#      docker compose --profile vectors up -d
#    Verify: `docker compose --profile vectors ps` shows postgres, web, orchestrator, qdrant all Up.
# 2. Settings → Purpose allocation → **Embedding** must point at a reachable embedding API (Ollama/OpenAI-compat).
# 3. Orchestrator polls PHP at OAAO_VAULT_JOB_POLL_BASE_URL below. Inside Compose use `http://web/vault/api` (not localhost).
#    PHP (`web`) also uses OAAO_QDRANT_URL for Vault embed-detail / delete-vector cleanup (default `http://qdrant:6333` in compose).
#    On first boot you may see INFO `waiting for Compose web service` for a few poll cycles until `web` joins DNS — harmless.
# 4. If orchestrator runs on the host (uvicorn on Mac), not in Docker, set:
#      OAAO_VAULT_JOB_POLL_BASE_URL=http://localhost:8080/vault/api
#      OAAO_QDRANT_URL=http://localhost:6333
#    Hostnames `web` / `qdrant` only resolve inside the Compose network.

OAAO_WEB_PORT=8080
OAAO_PG_HOST_PORT=5432

OAAO_PG_DB=oaao
OAAO_PG_USER=oaao
OAAO_PG_PASSWORD=oaao_dev

# Install wizard: PHP uses this automatically in Docker — URL field stays hidden unless you choose Advanced.
OAAO_PG_URL=postgresql://oaao:oaao_dev@postgres:5432/oaao
OAAO_SIDECAR_PORT=8103

# Python orchestrator — workspace chat SSE (must match secret below).
OAAO_ORCH_SHARED_SECRET=oaao_dev_shared_secret
OAAO_ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8103
OAAO_ORCHESTRATOR_PUBLIC_BASE=http://localhost:8103
# HTTPS pages: browser SSE uses Apache /sidecar → orchestrator (never PHP). Match your edge proxy if not Docker.
OAAO_ORCHESTRATOR_SIDECAR_PATH=/sidecar

# Post-stream quality workers (IQS / ACCS) — non-blocking after chat system/end.
# OAAO_QUEUE_POOLS_JSON=/app/python/config/queue_pools.docker.json

# Live meeting copilot (M1) — shared session/audio root on web + orchestrator.
# OAAO_LIVE_MEETING_ROOT=/var/www/html/sites/oaaoai/oaaoai/data/live-meeting
# OAAO_LIVE_MEETING_HOST_PATH=./docker/data/live-meeting

# Vault file storage (PHP) — bind-mount the same host path on `web` + `orchestrator` when running ingest sidecars that read binaries by absolute path from job payloads.
OAAO_VAULT_STORAGE=/var/www/html/storage/vault
OAAO_VAULT_STORAGE_HOST_PATH=./docker/data/vault

# View Transcript → Customize Summary prompt templates (Markdown bind mount into `web`).
# OAAO_TRANSCRIPT_SUMMARY_TEMPLATES_PATH=./docker/transcript-summary-templates
# OAAO_TRANSCRIPT_SUMMARY_TEMPLATES_DIR=/var/www/html/config/transcript-summary-templates

# Orchestrator → PHP vault job queue. Inside Compose keep `web` so both containers share the Compose network (`docker compose up -d`).
# Never use localhost/127.0.0.1 here from inside orchestrator—that points at the orchestrator pod, not Apache. Workarounds: `http://web/vault/api` (preferred)
# or Docker Desktop → `http://host.docker.internal:<OAAO_WEB_PORT>/vault/api`. From your Mac curl, localhost:8080 is fine but not inside the orchestrator env var.
# Requires `web` container Up; see “Vault document embed / RAG” block at top of this file.
OAAO_VAULT_JOB_POLL_BASE_URL=http://web/vault/api
OAAO_VAULT_JOB_POLL_INTERVAL_SEC=4
# Vault document embed: batch embeddings per HTTP request / parallel native-Ollama prompts (orchestrator `--> embedding API).
# OAAO_VAULT_EMBED_BATCH_SIZE=48
# OAAO_VAULT_EMBED_CONCURRENCY=12
# Stub processor finishes jobs as failed unless set to `complete` (smoke-test only — marks embed jobs completed without real ASR/embed).
OAAO_VAULT_JOB_STUB_MODE=fail
# ASR chunk size sent to transcription endpoint (MiB). Qwen/OpenAI-style APIs often cap ~25 MiB.
# OAAO_ASR_MAX_UPLOAD_MB=24
# Pad seconds before/after each ASR chunk core window (context overlap). Overridden by Settings → ASR purpose meta_json.
# OAAO_ASR_CHUNK_BUFFER_SEC=3

# Vault Speaker Mode — built-in FunASR sidecar (Settings → ASR → Speaker mode auto-starts via orchestrator).
# FunASR is NOT in the default compose profile — start once on Windows / Linux:
#   docker compose --profile funasr up -d --build funasr
# Verify: curl http://localhost:8765/health  →  {"status":"ok","mode":"stub"}
# Use FUNASR_ADAPTER_MODE=stub (default) — no ModelScope download. pipeline needs GPU + large models.
# If Settings auto-start fails on Windows, set OAAO_FUNASR_COMPOSE_ENABLED=0 and start funasr manually above.
# OAAO_FUNASR_HOST_PORT=8765
# OAAO_FUNASR_BASE_URL=http://funasr:8765
# OAAO_FUNASR_COMPOSE_ENABLED=1
# OAAO_COMPOSE_PROJECT_DIR=.
# FUNASR_ADAPTER_MODE=stub
# FUNASR_ADAPTER_MODE=pipeline
# FUNASR_ASR_MODEL=paraformer-zh
# FUNASR_SPK_MODEL=

# Embeddings (vault ingest + chat RAG): **not** configured here. PHP resolves URL + model from `oaao_purpose` → `oaao_endpoint` and sends them on each vault job / chat run. Optional: `endpoint.api_key_ref` as `env:VAR` — set that VAR in this file or your secret store.
# Optional operator override: native Ollama `POST /api/embeddings` vs OpenAI-compat `/v1/embeddings` is detected from the request URL path; you can still force native mode with `OAAO_EMBEDDING_NATIVE_OLLAMA=1` on the orchestrator if needed.
# OAAO_EMBEDDING_NATIVE_OLLAMA=

# Passed into orchestrator — used when chat `endpoint.api_key_ref` is empty (legacy default). Prefer `env:VAR` on each endpoint row so keys are explicit.
OPENAI_API_KEY=

# ── Operational model: runnable services inside Docker images; durable data only on outward-mounted dirs (below). Point at `./docker/data/…` or any host/NAS mount.
# Survives `docker compose down` / image rebuilds / accidental container delete — sync these dirs to S3 (e.g. aws s3 sync, rclone) or another host.
# Also include: ./backbone/config/oaaoai (install + database + sqlite_local config).
# PostgreSQL: copying OAAO_PG_DATA_PATH is a physical backup; add pg_dump on a schedule for logical backups.
OAAO_PG_DATA_PATH=./docker/data/postgres
# Postgres 16 on Linux: new host dir may need `sudo chown -R 999:999 <OAAO_PG_DATA_PATH>` (container postgres uid).
# Adjunct chat SQLite: host folder bind-mounted to /var/www/html/sites/oaaoai/oaaoai/auth/data — files live on the host; PHP uses the in-container path from auth.php.
# If chat returns “Split database unavailable”, the mount is usually not writable for www-data — fix host permissions or set OAAO_ADJUNCT_SQLITE below.
OAAO_AUTH_SQLITE_PATH=./docker/data/auth-local
# Slide designer projects (bind-mounted on web + orchestrator; same in-container path).
OAAO_SLIDE_PROJECT_PATH=./docker/data/slide-projects
OAAO_SLIDE_PROJECT_ROOT=/var/www/html/sites/oaaoai/oaaoai/auth/data/slide-projects
# Custom slide templates (PPTX import, LibreOffice render PNG, scoped JSON) — Razy distributor data/ (not auth/data).
OAAO_SLIDE_TEMPLATE_PATH=./docker/data/slide-templates
OAAO_SLIDE_TEMPLATE_CUSTOM_ROOT=/var/www/html/sites/oaaoai/oaaoai/data/slide-templates/custom
# Shared font cache (orchestrator bind-mount) — Anton / Plus Jakarta Sans / Carlito for LibreOffice + editor @font-face.
OAAO_FONT_CACHE_PATH=./docker/data/font-cache
OAAO_FONT_CACHE_DIR=/var/oaao/font-cache
# LibreOffice slide PNG count cap per template import (match your deck slide count).
OAAO_PPTX_RENDER_MAX_SLIDES=30
# Host bind for auth/data (sqlite + slide-templates); do not use as PHP env — use OAAO_AUTH_SQLITE_CONTAINER in compose.
OAAO_AUTH_SQLITE_CONTAINER=/var/www/html/sites/oaaoai/oaaoai/auth/data/oaao_local.sqlite

# Inside-container SQLite path override (survives chown failures on bind mounts). Example image-local file (not persisted across container rm unless you add a volume):
# OAAO_ADJUNCT_SQLITE=/var/www/html/data/oaao_local.sqlite
OAAO_ADJUNCT_SQLITE=

# Orchestrator REST target for Qdrant (service hostname `qdrant` — only when `docker compose --profile vectors up`).
# Without the vectors profile, vault embed logs `qdrant delete failed — Name or service not known` and jobs fail at upsert.
OAAO_QDRANT_URL=http://qdrant:6333
# Optional slug for derived collection names `{slug}_{global|ws_<id>|personal_u_<uid>|vault_<id>}` (tenant × scope buckets). Defaults to sanitized HTTP Host.
# Optional: force a single tenant slug for all requests (multi-host / Compose internal callbacks).
# When unset, slug follows Razy sites.inc.php domain + alias, then PostgreSQL oaao_tenant_host.
# OAAO_TENANT_SLUG=mytenant
#
# Platform admin console (tenant control plane — no chat/vault/AI on this host):
# OAAO_PLATFORM_ADMIN_HOST=admin.localhost
# OAAO_PLATFORM_HOSTS=admin.localhost,ops.example.com
# Production apex + customer hosts (Razy sites.inc.php + oaao_tenant_host seed):
# OAAO_APEX_DOMAIN=rayfung.hk
# OAAO_CUSTOMER_HOSTS=oaao.rayfung.hk
# OAAO_PLATFORM_ADMIN_HOST=admin.rayfung.hk
# After sites.inc.php / .htaccess changes, purge Cloudflare cache for /webassets/* (edge may cache old 404s).
# Dedicated operator account (seeded once on platform tenant — not shared with customer admin):
# OAAO_PLATFORM_ADMIN_PASSWORD=platform_admin
#
# Local Mac/host: map platform hostname to loopback (required on many setups):
#   sudo sh -c 'grep -q "admin.localhost" /etc/hosts || echo "127.0.0.1 admin.localhost" >> /etc/hosts'
# Then open: http://admin.localhost:8080/ — login: platform_admin / (password above or default platform_admin)
#
# Bootstrap platform admin (run once in Postgres after install):
#   UPDATE oaao_user SET tenant_id = (SELECT tenant_id FROM oaao_tenant WHERE slug='platform'),
#     role = 'platform_admin' WHERE login_name = 'your_admin';
# Optional fallback when PHP sends no collection (legacy); normally vault rows derive names automatically.
# OAAO_QDRANT_DEFAULT_COLLECTION=oaao_vault_vectors

# PDF ingest (orchestrator): sparse pypdf text per page always falls back to tesseract OCR (orchestrator image includes tesseract).
# OAAO_VAULT_PDF_OCR_MIN_CHARS=48
# OAAO_VAULT_PDF_OCR_LANG=eng+chi_tra
# OAAO_VAULT_PDF_OCR_DPI=200

# `--profile vectors` — Qdrant + Arango persistence (host paths; migrate old named volumes into these dirs if upgrading).
OAAO_QDRANT_DATA_PATH=./docker/data/qdrant
OAAO_ARANGO_DATA_PATH=./docker/data/arango
# QDRANT_HOST_PORT=6333
# ARANGO_HOST_PORT=8529
# ARANGO_ROOT_PASSWORD=oaao_dev_arango
# Graph API from other containers: http://arangodb:8529 (see oaao_vault.arango_* columns).
OAAO_ARANGO_URL=http://arangodb:8529
OAAO_ARANGO_DATABASE=oaao_vault
OAAO_ARANGO_USER=root
OAAO_ARANGO_PASSWORD=oaao_dev_arango
# Optional override for chat graph retrieval AQL (defaults to built-in entity/relation search).
# OAAO_ARANGO_RAG_AQL=
# OAAO_VAULT_GRAPH_BATCH_CHARS=5500
# OAAO_VAULT_GRAPH_MAX_BATCHES=24

# ── Evolution / tools (Phase 8–11) ───────────────────────────────────────────
# OAAO_INLINE_REFLECTION=1
# OAAO_REFLECTION_DISABLE=0
# OAAO_AGENT_TIMEOUT_SEC=300
# OAAO_KV_POOL_MAX_GB=40
# OAAO_SEARXNG_URL=http://searxng:8080
# OAAO_TOOL_SERVERS_PATH=/path/to/tool_servers.json
# OAAO_SKILLS_MANIFEST_PATH=/path/to/skills_manifest.json
# OAAO_TTS_BASE_URL=
# OAAO_SHELL_ESM_V=20260525-planner-evolution-v19
