# ─────────────────────────────────────────────────────────────────────────────
# OAAO.ai-v1 — PRODUCTION tier env template (W3-S2)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `docker/env` on the production host (NEVER commit the populated file).
#
# Hard rules for PROD:
#   1. NO plaintext secrets in this file. Every *(secret-manager only)* value
#      MUST resolve through a provider pointer:
#        OAAO_ORCH_SHARED_SECRET=aws-sm:us-east-1/oaao/orch
#        OAAO_PG_PASSWORD=vault:secret/oaao/prod#pg_password
#        OPENAI_API_KEY=file:/run/secrets/openai_key
#      Pointer scheme is implemented by oaao_orchestrator/_internal_secret.py
#      (W11-S2). See module docstring for scheme syntax.
#   2. NO wildcard CORS. NO `OAAO_CORS_ALLOW_WILDCARD=1`.
#   3. OAAO_PUBLIC_HTTPS=1 ALWAYS — assumes TLS terminates at edge.
#   4. OAAO_VAULT_JOB_STUB_MODE MUST be `fail` (real ASR/embed only).
#   5. Rotation: run scripts/rotate_dev_secret.sh weekly in staging, monthly in
#      prod via your secret-manager. Never rotate by editing this file in place.

# ── Required core ───────────────────────────────────────────────────────────
OAAO_WEB_PORT=8080
OAAO_SIDECAR_PORT=8103
OAAO_PG_HOST_PORT=5432

OAAO_PG_DB=oaao
OAAO_PG_USER=oaao
# (secret-manager only)
OAAO_PG_PASSWORD=aws-sm:us-east-1/oaao/prod#pg_password
OAAO_PG_URL=postgresql://oaao:aws-sm:us-east-1/oaao/prod#pg_password@postgres:5432/oaao

# ── Internal service secret (W3-S1 + W11-S2) — secret-manager only ─────────
OAAO_ORCH_SHARED_SECRET=aws-sm:us-east-1/oaao/prod#orch_shared_secret

# ── Orchestrator URLs ──────────────────────────────────────────────────────
OAAO_ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8103
OAAO_ORCHESTRATOR_PUBLIC_BASE=https://app.oaao.ai
OAAO_ORCHESTRATOR_SIDECAR_PATH=/sidecar
OAAO_PUBLIC_HTTPS=1

# Web search (Compose `searxng` — internal only; do not expose host port in prod unless needed)
OAAO_SEARXNG_URL=http://searxng:8080

# ── CORS (W10-S2) — explicit origins only, NEVER `*` ────────────────────────
OAAO_CORS_ALLOWED_ORIGINS=https://app.oaao.ai,https://admin.oaao.ai
OAAO_CORS_ALLOW_CREDENTIALS=1
# Leave OAAO_CORS_ALLOW_WILDCARD unset. If present + =1, treat as P0 incident.

# ── Vault / storage paths ──────────────────────────────────────────────────
OAAO_VAULT_STORAGE=/var/www/html/storage/vault
OAAO_VAULT_STORAGE_HOST_PATH=/srv/oaao/vault
OAAO_MINE_DATA_ROOT=/var/www/html/storage/mine
OAAO_MINE_DATA_HOST_PATH=/srv/oaao/mine
OAAO_PG_DATA_PATH=/srv/oaao/postgres
OAAO_AUTH_SQLITE_PATH=/srv/oaao/auth-local
OAAO_SLIDE_PROJECT_PATH=/srv/oaao/slide-projects
OAAO_FONT_CACHE_PATH=/srv/oaao/font-cache

# ── Vault job poll ─────────────────────────────────────────────────────────
OAAO_VAULT_JOB_POLL_BASE_URL=http://web/vault/api
OAAO_VAULT_JOB_POLL_INTERVAL_SEC=4
OAAO_VAULT_JOB_STUB_MODE=fail

# ── Upstream model credentials (secret-manager only) ───────────────────────
OPENAI_API_KEY=aws-sm:us-east-1/oaao/prod#openai_api_key

# ── Live meeting (M1) ──────────────────────────────────────────────────────
OAAO_LIVE_MEETING_ROOT=/var/www/html/sites/oaaoai/oaaoai/data/live-meeting
OAAO_LIVE_MEETING_HOST_PATH=/srv/oaao/live-meeting
