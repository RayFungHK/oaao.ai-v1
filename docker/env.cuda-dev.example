# CUDA dev machine — merge into docker/env (Linux + NVIDIA).
# oaao stack in Docker; Lance CUDA sidecar in compose profile lance-cuda (pipeline TBD → stub for now).

LANCE_DEV_BACKEND=cuda
LANCE_ADAPTER_MODE=stub
# When pipeline lands: LANCE_ADAPTER_MODE=pipeline

OAAO_LANCE_HOST_PORT=8787
OAAO_LANCE_BASE_URL=http://lance-cuda:8787

# Official ByteDance Lance weights (host path → mount into lance-cuda later)
# LANCE_MODEL_PATH=/data/models/Lance_3B
# LANCE_VIDEO_MODEL_PATH=/data/models/Lance_3B_Video

# Start:
#   docker compose --profile lance-cuda up -d --build lance-cuda
#   curl -s http://localhost:8787/health
# Expect: {"status":"ok","mode":"stub","dev_backend":"cuda","service":"lance"}
