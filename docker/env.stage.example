# ─────────────────────────────────────────────────────────────────────────────
# OAAO.ai-v1 — STAGING tier env template (W3-S2)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `docker/env` on the staging host (NEVER commit the populated file).
# All values marked *(secret-manager only)* MUST be injected at deploy time by
# AWS Secrets Manager / Vault / SOPS — never written here in plaintext.
# Use the OAAO_ORCH_SHARED_SECRET=env:VAR / file:/path / aws-sm: / vault: pointer
# scheme (W11-S2) to resolve from the deployment manager.

# ── Required core ───────────────────────────────────────────────────────────
OAAO_WEB_PORT=8080
OAAO_SIDECAR_PORT=8103
OAAO_PG_HOST_PORT=5432

OAAO_PG_DB=oaao_stage
OAAO_PG_USER=oaao_stage
# (secret-manager only) — never commit. Use aws-sm/vault provider or env:VAR.
OAAO_PG_PASSWORD=env:OAAO_PG_PASSWORD_INNER
OAAO_PG_URL=postgresql://oaao_stage:env:OAAO_PG_PASSWORD_INNER@postgres:5432/oaao_stage

# ── Internal service secret (W3-S1 + W11-S2) ───────────────────────────────
# Prefer pointer scheme so the literal never appears in container env dumps:
#   OAAO_ORCH_SHARED_SECRET=aws-sm:us-east-1/oaao-stage/orch
#   OAAO_ORCH_SHARED_SECRET=file:/run/secrets/oaao_orch_stage
OAAO_ORCH_SHARED_SECRET=env:OAAO_ORCH_SHARED_SECRET_INNER

# ── Orchestrator URLs ──────────────────────────────────────────────────────
OAAO_ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8103
OAAO_ORCHESTRATOR_PUBLIC_BASE=https://stage.oaao.ai
OAAO_ORCHESTRATOR_SIDECAR_PATH=/sidecar
OAAO_PUBLIC_HTTPS=1

# ── CORS (W10-S2) ───────────────────────────────────────────────────────────
# Comma-separated explicit origins. NEVER `*` in staging/prod.
OAAO_CORS_ALLOWED_ORIGINS=https://stage.oaao.ai,https://stage-admin.oaao.ai
OAAO_CORS_ALLOW_CREDENTIALS=1

# ── Vault / storage paths ──────────────────────────────────────────────────
OAAO_VAULT_STORAGE=/var/www/html/storage/vault
OAAO_VAULT_STORAGE_HOST_PATH=/srv/oaao-stage/vault
OAAO_MINE_DATA_ROOT=/var/www/html/storage/mine
OAAO_MINE_DATA_HOST_PATH=/srv/oaao-stage/mine
OAAO_PG_DATA_PATH=/srv/oaao-stage/postgres
OAAO_AUTH_SQLITE_PATH=/srv/oaao-stage/auth-local
OAAO_SLIDE_PROJECT_PATH=/srv/oaao-stage/slide-projects
OAAO_FONT_CACHE_PATH=/srv/oaao-stage/font-cache

# ── Vault job poll ─────────────────────────────────────────────────────────
OAAO_VAULT_JOB_POLL_BASE_URL=http://web/vault/api
OAAO_VAULT_JOB_POLL_INTERVAL_SEC=4
OAAO_VAULT_JOB_STUB_MODE=fail

# ── W8-S3 Redis canary Stage 2 (single orchestrator replica) ───────────────
# Requires: docker compose --profile redis-canary up -d
# OAAO_QUEUE_BACKEND=redis
# OAAO_QUEUE_REDIS_URL=redis://redis:6379/0
# Rollback: OAAO_QUEUE_BACKEND=memory + docker compose restart orchestrator

# ── Upstream model credentials (secret-manager only) ───────────────────────
# Per-endpoint api_key_ref=env:<VAR_NAME> is preferred over a global key.
OPENAI_API_KEY=env:OPENAI_API_KEY_INNER

# ── Live meeting (M1) ──────────────────────────────────────────────────────
OAAO_LIVE_MEETING_ROOT=/var/www/html/sites/oaaoai/oaaoai/data/live-meeting
OAAO_LIVE_MEETING_HOST_PATH=/srv/oaao-stage/live-meeting
