[Unit]
Description=OAAO evolution weekly auto-apply (orchestrator sidecar)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/opt/oaao/docker/env
WorkingDirectory=/opt/oaao
ExecStart=/opt/oaao/scripts/oaao_evolution_cron.sh weekly

[Install]
WantedBy=multi-user.target
